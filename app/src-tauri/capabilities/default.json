{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the trusted main webview only",
  "webviews": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**"
        }
      ]
    },
    "dialog:default",
    "deep-link:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-mkdir",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DESKTOP/*"
        },
        {
          "path": "$APPDATA/*"
        },
        {
          "path": "$APPDATA"
        }
      ]
    }
  ]
}
