+/**
+ * Serialize the full terminal state as a self-contained VT stream.
+ *
+ * The returned stream reconstructs the terminal (grid + scrollback + cursor +
+ * modes) when replayed into a fresh, same-size terminal. Unlike the plain
+ * terminal formatter, this is alternate-screen aware: when the alternate screen
+ * is active it emits the primary screen (scrollback + frame) first, then enters
+ * the alternate screen and emits its frame, so leaving the alternate screen
+ * after a restore reveals the primary content.
+ *
+ * The buffer is allocated using the provided allocator (or the default
+ * allocator if NULL). The caller frees it with ghostty_free(), passing the same
+ * allocator (or NULL for the default) that was used for the allocation.
+ *
+ * Carried attn patch (ghostty-vt-native.patch); candidate for upstream.
+ *
+ * @param allocator Pointer to allocator, or NULL to use the default allocator
+ * @param terminal The terminal to serialize (must not be NULL)
+ * @param out_ptr Pointer to receive the allocated buffer
+ * @param out_len Pointer to receive the length of the output in bytes
+ * @return GHOSTTY_SUCCESS on success, or an error code on failure
+ *
+ * @ingroup formatter
+ */
+GHOSTTY_API GhosttyResult ghostty_terminal_serialize_vt(
+    const GhosttyAllocator* allocator,
+    GhosttyTerminal terminal,
+    uint8_t** out_ptr,
+    size_t* out_len);
+
 /** @} */
 
